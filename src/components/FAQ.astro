---
import { faq } from '../data/faq';
import { site } from '../data/site';
---
<section class="section faq" id="faq"><div class="container faq-grid"><div class="faq-intro"><p class="eyebrow">Полезная информация</p><h2>Часто задаваемые вопросы</h2><p>Если не нашли ответ, напишите нам напрямую — так вы получите актуальную информацию.</p><a class="button button-small" href={site.vk} target="_blank" rel="noopener" data-event="click_vk_faq">Задать вопрос во ВКонтакте</a></div><div class="accordion">{faq.map(({ question, answer }) => <details><summary>{question}<span aria-hidden="true">+</span></summary><p>{answer}</p></details>)}</div></div></section>
