---
import { faq } from '../data/faq';
import { site } from '../data/site';
---
<section class="section faq" id="faq"><div class="container faq-grid"><div class="faq-intro"><p class="eyebrow">Полезная информация</p><h2>Часто задаваемые вопросы</h2><p>Если не нашли ответ, напишите нам напрямую — так вы получите актуальную информацию.</p><a href={site.telegram} target="_blank" rel="noopener" data-event="click_telegram_faq">Задать вопрос в Telegram →</a></div><div class="accordion">{faq.map(({ question, answer }) => <details><summary>{question}<span aria-hidden="true">+</span></summary><p>{answer}</p></details>)}</div></div></section>
