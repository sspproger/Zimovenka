---
const items = [
  ['Семейное производство', 'Общее дело, в котором результат связан с именем семьи.'],
  ['Небольшие партии', 'Ассортимент меняется, поэтому наличие лучше уточнять напрямую.'],
  ['Внимание к рецептуре', 'Состав и особенности каждой позиции можно узнать перед заказом.'],
  ['Ответственность', 'Прямой диалог помогает обсудить продукт и способ получения.'],
  ['Живое общение', 'Заказ оформляется без посредников — в Telegram или ВКонтакте.'],
  ['Уважение к традициям', 'Домашняя кухня и семейный стол задают характер бренда.'],
];
---
<section class="section advantages">
  <div class="container"><div class="section-heading"><p class="eyebrow">Свой характер</p><h2>Семейный подход к своему делу</h2></div><div class="advantage-grid">{items.map(([title, text], i) => <article><span aria-hidden="true">✦</span><h3>{title}</h3><p>{text}</p><small>{String(i + 1).padStart(2, '0')}</small></article>)}</div></div>
</section>
<section class="section lifestyle"><div class="container lifestyle-inner"><p class="eyebrow">Вместе — важнее</p><h2>Счастливая семья и дело, которое создаётся вместе</h2><p>Общие планы, уважение к труду, время на природе, домашняя еда и семейные праздники помогают сохранять главное — близость и внимание друг к другу.</p><div class="lifestyle-tags"><span>Совместный труд</span><span>Семейный стол</span><span>Домашние традиции</span><span>Баланс труда и отдыха</span></div></div></section>
