---
import { Image } from 'astro:assets';
import familyWorkPhoto from '../assets/family-work-product.jpg';
import familyExperiencePhoto from '../assets/family-experience.jpg';

const values = [
  ['Общий труд', 'Семейное дело растёт из ежедневной работы, взаимной поддержки и общей ответственности.'],
  ['Домашние традиции', 'Совместные праздники, общие заботы и добрые привычки создают особую атмосферу и передаются от старших к младшим.'],
  ['Уважение к опыту', 'Мы ценим советы старших, учимся у них и стараемся сохранить то хорошее, чему они нас научили.'],
];
---
<section class="section values" id="values">
  <div class="container"><div class="section-heading"><p class="eyebrow">То, что нас объединяет</p><h2>Семейное дело, которое связывает поколения</h2></div>
    <div class="value-grid">
      <figure class="value-visual"><Image class="value-side-photo" src={familyExperiencePhoto} alt="Забота о животных и передача семейного опыта" widths={[420, 720]} sizes="(max-width: 820px) 92vw, 33vw" loading="lazy" /></figure>
      <article class="value-copy">
        {values.map(([title, text]) => <div class="value-copy-item"><h3>{title}</h3><p>{text}</p></div>)}
      </article>
      <figure class="value-visual"><Image class="value-side-photo" src={familyWorkPhoto} alt="Домашняя колбаса семейного производства" widths={[420, 720]} sizes="(max-width: 820px) 92vw, 33vw" loading="lazy" /></figure>
    </div>
  </div>
</section>
