---
import { Image } from 'astro:assets';
import sharedWorkPhoto from '../assets/shared-work.jpg';
import homeTraditionsPhoto from '../assets/home-traditions.jpg';

const values = [
  ['Общий труд', 'Семейное дело растёт из ежедневной работы, взаимной поддержки и общей ответственности.'],
  ['Домашние традиции', 'Семейный стол хранит воспоминания, объединяет поколения и даёт повод быть вместе.'],
  ['Уважение к опыту', 'Опыт передаётся через внимание к работе близких и бережное отношение к привычным рецептам.'],
];
---
<section class="section values" id="values">
  <div class="container"><div class="section-heading"><p class="eyebrow">То, что нас объединяет</p><h2>Семейное дело, которое объединяет поколения</h2><p>Семейное дело — это не только производство. Это привычки, которые дети видят каждый день, уважение к работе близких, общие планы и радость от результата, созданного вместе.</p></div>
    <div class="value-grid">{values.map(([title, text], index) => <article class:list={{ 'has-photo': index < 2 }}>{index === 0 && <Image class="value-photo" src={sharedWorkPhoto} alt="Совместный семейный труд в усадьбе" widths={[420, 720]} sizes="(max-width: 820px) 92vw, 33vw" loading="lazy" />}{index === 1 && <Image class="value-photo" src={homeTraditionsPhoto} alt="Семья Лыковых сохраняет домашние и семейные традиции" widths={[420, 720]} sizes="(max-width: 820px) 92vw, 33vw" loading="lazy" />}<span>0{index + 1}</span><h3>{title}</h3><p>{text}</p></article>)}</div>
  </div>
</section>
