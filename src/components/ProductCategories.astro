---
import { Image } from 'astro:assets';
import homemadeSausagesPhoto from '../assets/product-homemade-sausages.jpg';
import dryCuredDelicaciesPhoto from '../assets/product-dry-cured-delicacies.png';
import smokedProductsPhoto from '../assets/product-smoked.jpg';
import hamsPhoto from '../assets/product-hams.jpg';
import sausagesPhoto from '../assets/product-sausages.jpg';
import grillSausagesPhoto from '../assets/product-grill-sausages.jpg';
import duckProductsPhoto from '../assets/product-duck.jpg';
import semiFinishedMeatPhoto from '../assets/product-semi-finished-meat.jpg';
import breakfastProductsPhoto from '../assets/product-breakfast.jpg';
import hamonPhoto from '../assets/product-hamon.jpg';
import seasonalProductsPhoto from '../assets/product-seasonal.jpg';
import giftSetsPhoto from '../assets/product-gift-sets.jpg';
import { productCategories } from '../data/products';
import { site } from '../data/site';

const productPhotos = {
  'Сырокопчёные колбасы': { src: homemadeSausagesPhoto, alt: 'Сырокопчёные колбасы «Зимовеньки»' },
  'Сыровяленые деликатесы': { src: dryCuredDelicaciesPhoto, alt: 'Сыровяленые деликатесы «Зимовеньки»' },
  'Хамон': { src: hamonPhoto, alt: 'Хамон «Зимовеньки»' },
  'Копчёная продукция': { src: smokedProductsPhoto, alt: 'Копчёная продукция «Зимовеньки»' },
  'Ветчины': { src: hamsPhoto, alt: 'Ветчины «Зимовеньки»' },
  'Сосиски и сардельки': { src: sausagesPhoto, alt: 'Сосиски и сардельки «Зимовеньки»' },
  'Колбаски для гриля': { src: grillSausagesPhoto, alt: 'Колбаски для гриля «Зимовеньки»' },
  'Продукция из утки': { src: duckProductsPhoto, alt: 'Продукция из утки «Зимовеньки»' },
  'Мясные полуфабрикаты': { src: semiFinishedMeatPhoto, alt: 'Мясные полуфабрикаты «Зимовеньки»' },
  'Продукты для завтрака': { src: breakfastProductsPhoto, alt: 'Продукты для завтрака «Зимовеньки»' },
  'Сезонные предложения': { src: seasonalProductsPhoto, alt: 'Сезонные предложения «Зимовеньки»' },
  'Подарочные наборы': { src: giftSetsPhoto, alt: 'Подарочные наборы «Зимовеньки»' },
};

const products = productCategories.map((product) => ({
  ...product,
  photo: productPhotos[product.title as keyof typeof productPhotos],
}));
---
<section class="section products" id="products">
  <div class="container"><div class="section-heading row-heading"><div><h2>Что готовит «Зимовенька»</h2></div></div>
    <div class="product-grid">{products.map((product) => <article class:list={['product-card', { 'has-photo': product.photo }]}>{product.photo ? <Image class="product-photo" src={product.photo.src} alt={product.photo.alt} widths={[420, 720]} sizes="(max-width: 820px) 92vw, 33vw" loading="lazy" /> : <div class="product-icon" aria-hidden="true">{product.icon}</div>}<h3>{product.title}</h3><div class="card-footer"><a href={site.telegram} target="_blank" rel="noopener" aria-label={`Уточнить наличие: ${product.title}`} data-event="click_product_availability">Уточнить наличие</a></div></article>)}</div>
    <div class="button-row centered"><a class="button" href={site.telegram} target="_blank" rel="noopener" data-event="click_telegram_products">Ассортимент в Telegram</a><a class="button button-ghost" href={site.vk} target="_blank" rel="noopener" data-event="click_vk_products">Ассортимент во ВКонтакте</a></div>
  </div>
</section>
